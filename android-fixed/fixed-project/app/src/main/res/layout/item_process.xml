<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:background="@drawable/bg_card" android:padding="9px"
    android:gravity="center_vertical" android:layout_marginBottom="3dp">
    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
        android:layout_height="wrap_content" android:orientation="vertical">
        <TextView android:id="@+id/tvProcName"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#E2E8F0" android:textSize="11sp" android:textStyle="bold"
            android:singleLine="true"/>
        <TextView android:id="@+id/tvProcMeta"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#4A5568" android:textSize="9sp"/>
    </LinearLayout>
    <TextView android:id="@+id/tvProcCpu"
        android:layout_width="42dp" android:layout_height="wrap_content"
        android:textSize="11sp" android:textStyle="bold"
        android:fontFamily="monospace" android:gravity="end"/>
    <Space android:layout_width="6dp" android:layout_height="1dp"/>
    <TextView android:id="@+id/btnKill"
        android:layout_width="26dp" android:layout_height="26dp"
        android:text="✕" android:textSize="11sp" android:textColor="#EF4444"
        android:gravity="center" android:background="@drawable/bg_btn_red_sm"
        android:clickable="true" android:focusable="true"/>
</LinearLayout>
