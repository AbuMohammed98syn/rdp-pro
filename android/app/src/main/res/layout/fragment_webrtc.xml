<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#050810" android:padding="14dp">

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="📹 مكالمة WebRTC" android:textColor="#FFFFFF"
        android:textSize="15sp" android:textStyle="bold" android:layout_marginBottom="12dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@drawable/bg_card" android:padding="12dp"
        android:orientation="vertical" android:layout_marginBottom="10dp">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Room ID" android:textColor="#64748B" android:textSize="10sp"
            android:layout_marginBottom="4dp"/>
        <EditText android:id="@+id/etRoomId"
            android:layout_width="match_parent" android:layout_height="40dp"
            android:background="@drawable/bg_field" android:textColor="#FFFFFF"
            android:textSize="13sp" android:paddingHorizontal="10dp"
            android:hint="rdp-default" android:hintTextColor="#4A5568"/>
    </LinearLayout>

    <TextView android:id="@+id/tvRtcStatus"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="● غير متصل" android:textColor="#4A5568"
        android:textSize="12sp" android:layout_marginBottom="10dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">
        <Button android:id="@+id/btnCall"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="44dp"
            android:text="📞 اتصال" android:textColor="#FFFFFF" android:textSize="12sp"
            android:background="@drawable/bg_btn_green"/>
        <Space android:layout_width="8dp" android:layout_height="1dp"/>
        <Button android:id="@+id/btnHangup"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="44dp"
            android:text="📵 إنهاء" android:textColor="#FFFFFF" android:textSize="12sp"
            android:background="@drawable/bg_btn_red" android:enabled="false"/>
        <Space android:layout_width="8dp" android:layout_height="1dp"/>
        <Button android:id="@+id/btnMute"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="44dp"
            android:text="🎤 صوت" android:textColor="#94A3B8" android:textSize="12sp"
            android:background="@drawable/bg_btn_dark"/>
    </LinearLayout>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="سجل الأحداث" android:textColor="#4A5568"
        android:textSize="9sp" android:layout_marginBottom="4dp"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:background="@drawable/bg_card">
        <TextView android:id="@+id/tvRtcLog"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:padding="10dp" android:textColor="#64748B"
            android:textSize="10sp" android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.4"/>
    </ScrollView>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="⚠️ يتطلب إضافة مكتبة WebRTC: org.webrtc:google-webrtc"
        android:textColor="#F59E0B" android:textSize="9sp"
        android:gravity="center" android:layout_marginTop="6dp"/>
</LinearLayout>