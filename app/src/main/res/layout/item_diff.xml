<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:background="@drawable/bg_card" android:padding="10dp"
    android:gravity="center_vertical" android:layout_marginBottom="4dp">
    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
        android:layout_height="wrap_content" android:orientation="vertical">
        <TextView android:id="@+id/tvDiffName"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="#FFFFFF" android:textSize="11sp"
            android:fontFamily="monospace" android:textStyle="bold"/>
        <TextView android:id="@+id/tvDiffStatus"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="9sp" android:layout_marginTop="2dp"/>
        <TextView android:id="@+id/tvDiffSize"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="#4A5568" android:textSize="8sp" android:fontFamily="monospace"/>
    </LinearLayout>
    <Button android:id="@+id/btnDiffSync"
        android:layout_width="32dp" android:layout_height="28dp"
        android:text="↑" android:textSize="12sp" android:textColor="#22D3EE"
        android:background="@drawable/bg_btn_dark" android:layout_marginEnd="4dp"/>
    <Button android:id="@+id/btnDiffDel"
        android:layout_width="28dp" android:layout_height="28dp"
        android:text="🗑" android:textSize="10sp" android:textColor="#EF4444"
        android:background="@drawable/bg_btn_dark"/>
</LinearLayout>
