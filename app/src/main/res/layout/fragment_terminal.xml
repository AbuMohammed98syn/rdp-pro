<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#050810">

    <!-- CWD header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="32dp"
        android:background="#080D17" android:gravity="center_vertical"
        android:paddingHorizontal="10dp">
        <TextView android:id="@+id/tvCwd"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="📂 ..."
            android:textColor="#4A5568" android:textSize="10sp"
            android:fontFamily="monospace"/>
        <Button android:id="@+id/btnClearOutput"
            android:layout_width="wrap_content" android:layout_height="22dp"
            android:text="مسح" android:textSize="9sp"
            android:textColor="#64748B" android:background="@drawable/bg_btn_dark"
            android:paddingHorizontal="8dp"/>
    </LinearLayout>

    <!-- Output area -->
    <ScrollView android:id="@+id/svOutput"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#050810"
        android:padding="8dp">
        <TextView android:id="@+id/tvOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E2E8F0" android:textSize="11sp"
            android:fontFamily="monospace" android:lineSpacingMultiplier="1.4"/>
    </ScrollView>

    <!-- Quick command buttons — horizontal scroll -->
    <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="#080D17" android:paddingVertical="4dp">
        <LinearLayout android:layout_width="wrap_content" android:layout_height="28dp"
            android:gravity="center_vertical" android:paddingHorizontal="6dp">

            <!-- Networking -->
            <Button android:id="@+id/tcmdIpconfig" android:layout_width="wrap_content"
                android:layout_height="match_parent" android:text="ipconfig"
                android:textSize="9sp" android:textColor="#22D3EE"
                android:background="@drawable/bg_btn_dark" android:paddingHorizontal="8dp"
                android:layout_marginEnd="4dp"/>
            <Button android:id="@+id/tcmdPing" android:layout_width="wrap_content"
                android:layout_height="match_parent" android:text="ping"
                android:textSize="9sp" android:textColor="#22D3EE"
                android:background="@drawable/bg_btn_dark" android:paddingHorizontal="8dp"
                android:layout_marginEnd="4dp"/>
            <Button android:id="@+id/tcmdNetstat" android:layout_width="wrap_content"
                android:layout_height="match_parent" android:text="netstat"
                android:textSize="9sp" android:textColor="#22D3EE"
                android:background="@drawable/bg_btn_dark" android:paddingHorizontal="8dp"
                android:layout_marginEnd="4dp"/>
            <Button android:id="@+id/tcmdTracert" android:layout_width="wrap_content"
                android:layout_height="match_parent" android:text="tracert"
                android:textSize="9sp" android:textColor="#22D3EE"
                android:background="@drawable/bg_btn_dark" android:paddingHorizontal="8dp"
                android:layout_marginEnd="8dp"/>

            <!-- System -->
            <Button android:id="@+id/tcmdSysteminfo" android:layout_width="wrap_content"
                android:layout_height="match_parent" android:text="sysinfo"
                android:textSize="9sp" android:textColor="#A78BFA"
                android:background="@drawable/bg_btn_dark" android:paddingHorizontal="8dp"
                android:layout_marginEnd="4dp"/>
            <Button android:id="@+id/tcmdTasklist" android:layout_width="wrap_content"
                android:layout_height="match_parent" android:text="tasklist"
                android:textSize="9sp" android:textColor="#A78BFA"
                android:background="@drawable/bg_btn_dark" android:paddingHorizontal="8dp"
                android:layout_marginEnd="4dp"/>
            <Button android:id="@+id/tcmdDf" android:layout_width="wrap_content"
                android:layout_height="match_parent" android:text="df -h"
                android:textSize="9sp" android:textColor="#A78BFA"
                android:background="@drawable/bg_btn_dark" android:paddingHorizontal="8dp"
                android:layout_marginEnd="4dp"/>
            <Button android:id="@+id/tcmdWhoami" android:layout_width="wrap_content"
                android:layout_height="match_parent" android:text="whoami"
                android:textSize="9sp" android:textColor="#A78BFA"
                android:background="@drawable/bg_btn_dark" android:paddingHorizontal="8dp"
                android:layout_marginEnd="8dp"/>

            <!-- Files -->
            <Button android:id="@+id/tcmdDir" android:layout_width="wrap_content"
                android:layout_height="match_parent" android:text="dir"
                android:textSize="9sp" android:textColor="#10B981"
                android:background="@drawable/bg_btn_dark" android:paddingHorizontal="8dp"
                android:layout_marginEnd="4dp"/>
            <Button android:id="@+id/tcmdLs" android:layout_width="wrap_content"
                android:layout_height="match_parent" android:text="ls -la"
                android:textSize="9sp" android:textColor="#10B981"
                android:background="@drawable/bg_btn_dark" android:paddingHorizontal="8dp"
                android:layout_marginEnd="4dp"/>
            <Button android:id="@+id/tcmdPwd" android:layout_width="wrap_content"
                android:layout_height="match_parent" android:text="pwd"
                android:textSize="9sp" android:textColor="#10B981"
                android:background="@drawable/bg_btn_dark" android:paddingHorizontal="8dp"
                android:layout_marginEnd="8dp"/>

            <!-- Advanced -->
            <Button android:id="@+id/tcmdGpupdate" android:layout_width="wrap_content"
                android:layout_height="match_parent" android:text="gpupdate"
                android:textSize="9sp" android:textColor="#F59E0B"
                android:background="@drawable/bg_btn_dark" android:paddingHorizontal="8dp"
                android:layout_marginEnd="4dp"/>
            <Button android:id="@+id/tcmdSfc" android:layout_width="wrap_content"
                android:layout_height="match_parent" android:text="sfc"
                android:textSize="9sp" android:textColor="#F59E0B"
                android:background="@drawable/bg_btn_dark" android:paddingHorizontal="8dp"
                android:layout_marginEnd="4dp"/>
            <Button android:id="@+id/tcmdDiskclean" android:layout_width="wrap_content"
                android:layout_height="match_parent" android:text="cleanmgr"
                android:textSize="9sp" android:textColor="#F59E0B"
                android:background="@drawable/bg_btn_dark" android:paddingHorizontal="8dp"/>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Input bar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="44dp"
        android:background="#080D17" android:gravity="center_vertical" android:padding="6dp">
        <EditText android:id="@+id/etCmd"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent"
            android:background="@drawable/bg_field"
            android:textColor="#FFFFFF" android:textSize="12sp"
            android:hint="$ أدخل أمر..." android:textColorHint="#4A5568"
            android:paddingHorizontal="10dp" android:fontFamily="monospace"
            android:inputType="textNoSuggestions"
            android:imeOptions="actionSend" android:layout_marginEnd="6dp"/>
        <Button android:id="@+id/btnSendCmd"
            android:layout_width="50dp" android:layout_height="match_parent"
            android:text="▶" android:textColor="#FFFFFF" android:textSize="14sp"
            android:background="@drawable/bg_btn_blue"/>
    </LinearLayout>

</LinearLayout>
