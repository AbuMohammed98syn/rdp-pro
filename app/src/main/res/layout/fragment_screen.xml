<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Main content column -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#000000">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="#090D17"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp">

            <Button android:id="@+id/btnTrackpad"
                android:layout_width="wrap_content" android:layout_height="28dp"
                android:text="Trackpad" android:textSize="9sp"
                android:textColor="#60A5FA" android:background="@drawable/bg_mode_on"
                android:paddingHorizontal="10dp"/>
            <Space android:layout_width="4dp" android:layout_height="1dp"/>
            <Button android:id="@+id/btnDirect"
                android:layout_width="wrap_content" android:layout_height="28dp"
                android:text="مباشر" android:textSize="9sp"
                android:textColor="#4A5568" android:background="@drawable/bg_mode_off"
                android:paddingHorizontal="10dp"/>
            <Space android:layout_width="4dp" android:layout_height="1dp"/>
            <Button android:id="@+id/btnGesture"
                android:layout_width="wrap_content" android:layout_height="28dp"
                android:text="إيماءة" android:textSize="9sp"
                android:textColor="#4A5568" android:background="@drawable/bg_mode_off"
                android:paddingHorizontal="10dp"/>

            <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

            <!-- Record button -->
            <Button android:id="@+id/btnRecord"
                android:layout_width="wrap_content" android:layout_height="26dp"
                android:text="⏺" android:textSize="10sp"
                android:textColor="#EF4444" android:background="@drawable/bg_btn_dark"
                android:paddingHorizontal="8dp"/>
            <Space android:layout_width="4dp" android:layout_height="1dp"/>
            <!-- Chat toggle button -->
            <Button android:id="@+id/btnChatToggle"
                android:layout_width="wrap_content" android:layout_height="26dp"
                android:text="💬" android:textSize="10sp"
                android:textColor="#60A5FA" android:background="@drawable/bg_btn_dark"
                android:paddingHorizontal="8dp"/>

            <TextView android:id="@+id/tvMode"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#4A5568" android:textSize="9sp"
                android:layout_marginStart="6dp"/>
        </LinearLayout>

        <!-- Screen image (relative for cursor overlay) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="3">

            <ImageView android:id="@+id/imgScreen"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#000000"
                android:scaleType="fitCenter"/>

            <!-- Recording indicator -->
            <TextView android:id="@+id/tvRecIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏺ تسجيل"
                android:textColor="#EF4444"
                android:textSize="10sp"
                android:background="#CC000000"
                android:padding="4dp"
                android:layout_margin="8dp"
                android:layout_gravity="top|start"
                android:visibility="gone"/>

            <!-- Floating cursor dot -->
            <View android:id="@+id/cursorDot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/dot_green"
                android:visibility="invisible"/>

        </FrameLayout>

        <!-- Trackpad -->
        <View android:id="@+id/trackpad"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_margin="8dp"
            android:background="@drawable/bg_card"/>

        <!-- Bottom mouse buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="#090D17"
            android:padding="4dp">

            <Button android:id="@+id/btnLeft"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="match_parent"
                android:text="يسار" android:textSize="10sp"
                android:textColor="#10B981" android:background="@drawable/bg_btn_green"/>
            <Space android:layout_width="3dp" android:layout_height="1dp"/>
            <Button android:id="@+id/btnDouble"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="match_parent"
                android:text="×2" android:textSize="10sp"
                android:textColor="#60A5FA" android:background="@drawable/bg_btn_blue"/>
            <Space android:layout_width="3dp" android:layout_height="1dp"/>
            <Button android:id="@+id/btnRight"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="match_parent"
                android:text="يمين" android:textSize="10sp"
                android:textColor="#F87171" android:background="@drawable/bg_btn_red"/>
            <Space android:layout_width="3dp" android:layout_height="1dp"/>
            <Button android:id="@+id/btnScrollUp"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="match_parent"
                android:text="↑" android:textSize="14sp"
                android:textColor="#94A3B8" android:background="@drawable/bg_btn_dark"/>
            <Space android:layout_width="3dp" android:layout_height="1dp"/>
            <Button android:id="@+id/btnScrollDown"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="match_parent"
                android:text="↓" android:textSize="14sp"
                android:textColor="#94A3B8" android:background="@drawable/bg_btn_dark"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Chat overlay panel (slides up from bottom) -->
    <LinearLayout
        android:id="@+id/chatPanel"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#EE0D1528"
        android:visibility="gone">

        <!-- Chat header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:background="#0A1A3A">
            <TextView
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="💬 دردشة مع الحاسوب"
                android:textColor="#E2E8F0"
                android:textSize="12sp" android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● متصل"
                android:textColor="#10B981"
                android:textSize="10sp"/>
        </LinearLayout>

        <!-- Chat messages -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvChat"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="8dp"
            android:clipToPadding="false"/>

        <!-- Chat input row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:gravity="center_vertical"
            android:padding="6dp"
            android:background="#080F20">

            <EditText
                android:id="@+id/chatInput"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="match_parent"
                android:background="@drawable/bg_field"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:hint="اكتب رسالة..."
                android:textColorHint="#4A5568"
                android:paddingHorizontal="10dp"
                android:inputType="textMultiLine"
                android:maxLines="1"
                android:layout_marginEnd="6dp"/>

            <Button
                android:id="@+id/btnChatSend"
                android:layout_width="44dp"
                android:layout_height="match_parent"
                android:text="↑"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:background="@drawable/bg_btn_blue"/>
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
