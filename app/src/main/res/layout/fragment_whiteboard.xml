<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#050810">

    <!-- Top toolbar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="44dp"
        android:background="#080D17" android:gravity="center_vertical"
        android:paddingHorizontal="8dp">

        <!-- Tool buttons -->
        <Button android:id="@+id/tbPen" android:layout_width="36dp" android:layout_height="30dp"
            android:text="✏" android:textSize="14sp" android:textColor="#60A5FA"
            android:background="@drawable/bg_mode_on" android:padding="0dp"
            android:layout_marginEnd="3dp"/>
        <Button android:id="@+id/tbLine" android:layout_width="36dp" android:layout_height="30dp"
            android:text="╱" android:textSize="14sp" android:textColor="#4A5568"
            android:background="@drawable/bg_mode_off" android:padding="0dp"
            android:layout_marginEnd="3dp"/>
        <Button android:id="@+id/tbRect" android:layout_width="36dp" android:layout_height="30dp"
            android:text="▭" android:textSize="14sp" android:textColor="#4A5568"
            android:background="@drawable/bg_mode_off" android:padding="0dp"
            android:layout_marginEnd="3dp"/>
        <Button android:id="@+id/tbCircle" android:layout_width="36dp" android:layout_height="30dp"
            android:text="○" android:textSize="14sp" android:textColor="#4A5568"
            android:background="@drawable/bg_mode_off" android:padding="0dp"
            android:layout_marginEnd="3dp"/>
        <Button android:id="@+id/tbEraser" android:layout_width="36dp" android:layout_height="30dp"
            android:text="⌫" android:textSize="12sp" android:textColor="#4A5568"
            android:background="@drawable/bg_mode_off" android:padding="0dp"
            android:layout_marginEnd="6dp"/>

        <!-- Stroke size -->
        <SeekBar android:id="@+id/seekStroke"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content"
            android:max="20" android:progress="4"
            android:progressTint="#3B82F6"
            android:thumbTint="#3B82F6"
            android:layout_marginEnd="6dp"/>

        <!-- Undo / Clear -->
        <Button android:id="@+id/btnUndo" android:layout_width="32dp" android:layout_height="28dp"
            android:text="↩" android:textSize="13sp" android:textColor="#94A3B8"
            android:background="@drawable/bg_btn_dark" android:padding="0dp"
            android:layout_marginEnd="3dp"/>
        <Button android:id="@+id/btnClear" android:layout_width="32dp" android:layout_height="28dp"
            android:text="✕" android:textSize="12sp" android:textColor="#EF4444"
            android:background="@drawable/bg_btn_dark" android:padding="0dp"
            android:layout_marginEnd="3dp"/>
        <Button android:id="@+id/btnSendBoard" android:layout_width="wrap_content" android:layout_height="28dp"
            android:text="📤" android:textSize="12sp" android:textColor="#10B981"
            android:background="@drawable/bg_btn_dark" android:paddingHorizontal="6dp"/>
    </LinearLayout>

    <!-- Drawing area -->
    <FrameLayout android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1">

        <com.rdppro.rdpro.WhiteboardFragment.BoardView
            android:id="@+id/boardView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#0D1528"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="ارسم هنا — سيُرسل إلى الحاسوب"
            android:textColor="#1E293B" android:textSize="14sp"
            android:textStyle="italic"/>

    </FrameLayout>

    <!-- Color palette -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="36dp"
        android:background="#080D17" android:gravity="center"
        android:paddingHorizontal="12dp">

        <View android:id="@+id/colBlue" android:layout_width="22dp" android:layout_height="22dp"
            android:background="#3B82F6" android:layout_marginHorizontal="4dp"
            android:clickable="true" android:focusable="true"/>
        <View android:id="@+id/colRed" android:layout_width="22dp" android:layout_height="22dp"
            android:background="#EF4444" android:layout_marginHorizontal="4dp"
            android:clickable="true" android:focusable="true"/>
        <View android:id="@+id/colGreen" android:layout_width="22dp" android:layout_height="22dp"
            android:background="#10B981" android:layout_marginHorizontal="4dp"
            android:clickable="true" android:focusable="true"/>
        <View android:id="@+id/colYellow" android:layout_width="22dp" android:layout_height="22dp"
            android:background="#F59E0B" android:layout_marginHorizontal="4dp"
            android:clickable="true" android:focusable="true"/>
        <View android:id="@+id/colWhite" android:layout_width="22dp" android:layout_height="22dp"
            android:background="#FFFFFF" android:layout_marginHorizontal="4dp"
            android:clickable="true" android:focusable="true"/>
        <View android:id="@+id/colBlack" android:layout_width="22dp" android:layout_height="22dp"
            android:background="#111827" android:layout_marginHorizontal="4dp"
            android:clickable="true" android:focusable="true"
            style="@style/Widget.AppCompat.Button"/>

    </LinearLayout>

</LinearLayout>
