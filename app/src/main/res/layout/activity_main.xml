<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050810">

    <!-- ── Header Bar (swipe-down triggers smart cmd bar) ── -->
    <LinearLayout
        android:id="@+id/headerBar"
        android:layout_width="0dp"
        android:layout_height="42dp"
        android:background="#080D17"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- App logo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🖥️"
            android:textSize="16sp"
            android:layout_marginEnd="6dp"/>

        <!-- Address -->
        <TextView
            android:id="@+id/tvAddr"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="#E2E8F0"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textStyle="bold"/>

        <!-- Permission level badge -->
        <TextView
            android:id="@+id/tvPermLevel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡ كامل"
            android:textSize="10sp"
            android:background="@drawable/bg_badge"
            android:padding="3dp"
            android:layout_marginHorizontal="6dp"/>

        <!-- FPS/Latency -->
        <TextView
            android:id="@+id/tvFps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0fps 0ms"
            android:textColor="#4A5568"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:layout_marginEnd="8dp"/>

        <!-- Status dot -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● متصل"
            android:textColor="#10B981"
            android:textSize="10sp"
            android:layout_marginEnd="8dp"/>

        <!-- Theme toggle -->
        <Button
            android:id="@+id/btnToggleTheme"
            android:layout_width="28dp"
            android:layout_height="24dp"
            android:text="🌙"
            android:textSize="11sp"
            android:background="@drawable/bg_btn_dark"
            android:padding="0dp"
            android:layout_marginEnd="4dp"/>

        <!-- Lang toggle -->
        <Button
            android:id="@+id/btnToggleLang"
            android:layout_width="28dp"
            android:layout_height="24dp"
            android:text="EN"
            android:textSize="8sp"
            android:textColor="#94A3B8"
            android:background="@drawable/bg_btn_dark"
            android:padding="0dp"/>

    </LinearLayout>

    <!-- ── Smart Command Bar (hidden by default) ── -->
    <LinearLayout
        android:id="@+id/smartCmdBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#EE080D17"
        android:padding="10dp"
        android:visibility="gone"
        android:elevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/headerBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Search/command input -->
        <EditText
            android:id="@+id/etCmdQuery"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:background="@drawable/bg_field"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:hint="⚡ أمر سريع... (lock / sleep / dir)"
            android:textColorHint="#4A5568"
            android:paddingHorizontal="12dp"
            android:fontFamily="monospace"
            android:inputType="text"
            android:imeOptions="actionSend"
            android:layout_marginBottom="8dp"/>

        <!-- Quick chips row -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center_vertical">

                <Button android:id="@+id/chip_lock"
                    android:layout_width="wrap_content" android:layout_height="26dp"
                    android:text="🔒 قفل" android:textSize="10sp" android:textColor="#94A3B8"
                    android:background="@drawable/bg_btn_dark" android:paddingHorizontal="10dp"
                    android:layout_marginEnd="5dp"/>
                <Button android:id="@+id/chip_sleep"
                    android:layout_width="wrap_content" android:layout_height="26dp"
                    android:text="💤 سكون" android:textSize="10sp" android:textColor="#94A3B8"
                    android:background="@drawable/bg_btn_dark" android:paddingHorizontal="10dp"
                    android:layout_marginEnd="5dp"/>
                <Button android:id="@+id/chip_screenshot"
                    android:layout_width="wrap_content" android:layout_height="26dp"
                    android:text="📷 صورة" android:textSize="10sp" android:textColor="#94A3B8"
                    android:background="@drawable/bg_btn_dark" android:paddingHorizontal="10dp"
                    android:layout_marginEnd="5dp"/>
                <Button android:id="@+id/chip_explorer"
                    android:layout_width="wrap_content" android:layout_height="26dp"
                    android:text="🗂 Explorer" android:textSize="10sp" android:textColor="#94A3B8"
                    android:background="@drawable/bg_btn_dark" android:paddingHorizontal="10dp"
                    android:layout_marginEnd="5dp"/>
                <Button android:id="@+id/chip_task"
                    android:layout_width="wrap_content" android:layout_height="26dp"
                    android:text="📊 مهام" android:textSize="10sp" android:textColor="#94A3B8"
                    android:background="@drawable/bg_btn_dark" android:paddingHorizontal="10dp"
                    android:layout_marginEnd="5dp"/>
                <Button android:id="@+id/chip_ps"
                    android:layout_width="wrap_content" android:layout_height="26dp"
                    android:text="💻 PS" android:textSize="10sp" android:textColor="#94A3B8"
                    android:background="@drawable/bg_btn_dark" android:paddingHorizontal="10dp"/>

            </LinearLayout>
        </HorizontalScrollView>

    </LinearLayout>

    <!-- ── Fragment Container ── -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/headerBar"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── Bottom Navigation ── -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#080D17"
        app:itemIconTint="@color/nav_tint"
        app:itemTextColor="@color/nav_tint"
        app:itemActiveIndicatorColor="#1A2540"
        app:menu="@menu/bottom_nav_menu"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
