<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050810">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Logo + title -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:gravity="center" android:orientation="vertical"
            android:layout_marginTop="16dp" android:layout_marginBottom="20dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🖥️" android:textSize="40sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="RDP Pro" android:textColor="#FFFFFF"
                android:textSize="22sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="v4.1" android:textColor="#4A5568" android:textSize="11sp"/>
        </LinearLayout>

        <!-- ── Connection details ── -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="معلومات الاتصال" android:textColor="#64748B"
            android:textSize="10sp" android:textAllCaps="true" android:letterSpacing="0.08"
            android:layout_marginBottom="6dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_card" android:padding="14dp"
            android:orientation="vertical" android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="IP الحاسوب"
                app:boxStrokeColor="#1A2540"
                app:boxBackgroundColor="#0D1528"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                android:layout_marginBottom="8dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etIp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="#FFFFFF" android:textColorHint="#4A5568"
                    android:inputType="textUri" android:imeOptions="actionNext"
                    android:fontFamily="monospace"/>
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:hint="Port"
                    app:boxStrokeColor="#1A2540" app:boxBackgroundColor="#0D1528"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    android:layout_marginEnd="8dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPort"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textColor="#FFFFFF" android:textColorHint="#4A5568"
                        android:inputType="number" android:imeOptions="actionNext"
                        android:fontFamily="monospace"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- HTTPS switch -->
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="HTTPS" android:textColor="#4A5568" android:textSize="10sp"/>
                    <Switch android:id="@+id/switchHttps"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:thumbTint="#3B82F6" android:trackTint="#1E3A5F"/>
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="Token"
                app:boxStrokeColor="#1A2540" app:boxBackgroundColor="#0D1528"
                app:endIconMode="password_toggle"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etToken"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="#FFFFFF" android:textColorHint="#4A5568"
                    android:inputType="textPassword"
                    android:fontFamily="monospace"/>
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- ── Permission Level ── -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="مستوى الصلاحيات" android:textColor="#64748B"
            android:textSize="10sp" android:textAllCaps="true" android:letterSpacing="0.08"
            android:layout_marginBottom="6dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_card" android:padding="12dp"
            android:gravity="center_vertical" android:layout_marginBottom="12dp">
            <TextView android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="نوع الوصول" android:textColor="#94A3B8" android:textSize="13sp"/>
            <Spinner android:id="@+id/spinnerPerm"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"
                android:backgroundTint="#3B82F6"/>
        </LinearLayout>

        <!-- ── Wake-on-LAN ── -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Wake-on-LAN" android:textColor="#64748B"
            android:textSize="10sp" android:textAllCaps="true" android:letterSpacing="0.08"
            android:layout_marginBottom="6dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_card" android:padding="12dp"
            android:gravity="center_vertical" android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"
                android:hint="MAC Address"
                app:boxStrokeColor="#1A2540" app:boxBackgroundColor="#0D1528"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                android:layout_marginEnd="8dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etMac"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="#FFFFFF" android:textColorHint="#4A5568"
                    android:inputType="text" android:fontFamily="monospace"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWol"
                android:layout_width="wrap_content" android:layout_height="40dp"
                android:text="🔌 إيقاظ"
                android:textColor="#F59E0B" android:textSize="11sp"
                app:backgroundTint="#110A00" app:strokeColor="#F59E0B"
                app:strokeWidth="1dp" app:cornerRadius="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        </LinearLayout>

        <!-- ── Status ── -->
        <TextView android:id="@+id/tvStatus"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="#4A5568" android:textSize="12sp"
            android:gravity="center" android:layout_marginBottom="8dp"
            android:visibility="invisible"/>

        <!-- ── Connect + QR buttons ── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConnect"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="⚡ اتصال"
            android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"
            app:backgroundTint="#2563EB" app:cornerRadius="12dp"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQr"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:text="📷 مسح QR Code"
            android:textColor="#22D3EE" android:textSize="13sp"
            app:backgroundTint="#050F20" app:strokeColor="#0E7490"
            app:strokeWidth="1dp" app:cornerRadius="10dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginBottom="12dp"/>

        <!-- ── History ── -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="الاتصالات السابقة" android:textColor="#64748B"
            android:textSize="10sp" android:textAllCaps="true" android:letterSpacing="0.08"
            android:layout_marginBottom="6dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>
