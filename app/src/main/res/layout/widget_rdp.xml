<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_widget"
    android:padding="12dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:gravity="center_vertical" android:layout_marginBottom="8dp">
        <TextView android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="🖥️ RDP Pro" android:textColor="#FFFFFF"
            android:textSize="13sp" android:textStyle="bold"/>
        <TextView android:id="@+id/widgetStatus"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="● غير متصل" android:textColor="#EF4444" android:textSize="10sp"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content">
        <Button android:id="@+id/widgetBtnConnect"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="32dp"
            android:text="⚡ اتصال" android:textColor="#FFFFFF" android:textSize="11sp"
            android:background="@drawable/bg_btn_blue"
            android:layout_marginEnd="4dp"/>
        <Button android:id="@+id/widgetBtnLock"
            android:layout_width="wrap_content" android:layout_height="32dp"
            android:text="🔒" android:textSize="12sp"
            android:background="@drawable/bg_btn_dark"
            android:paddingHorizontal="8dp"/>
    </LinearLayout>

    <TextView android:id="@+id/widgetStats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0fps  0ms  CPU 0%"
        android:textColor="#4A5568" android:textSize="9sp"
        android:fontFamily="monospace"
        android:layout_marginTop="6dp"/>

</LinearLayout>
