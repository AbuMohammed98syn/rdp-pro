<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#050810">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="16dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@drawable/bg_card" android:padding="16dp"
        android:orientation="vertical" android:layout_marginBottom="12dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🔌 Wake-on-LAN" android:textColor="#F59E0B"
            android:textSize="15sp" android:textStyle="bold" android:layout_marginBottom="14dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="MAC Address" android:textColor="#64748B"
            android:textSize="11sp" android:layout_marginBottom="4dp"/>

        <EditText android:id="@+id/etWolMac"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:background="@drawable/bg_field" android:textColor="#FFFFFF"
            android:textSize="13sp" android:hint="AA:BB:CC:DD:EE:FF"
            android:textColorHint="#4A5568" android:paddingHorizontal="12dp"
            android:fontFamily="monospace" android:inputType="text"
            android:layout_marginBottom="10dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Broadcast IP" android:textColor="#64748B"
            android:textSize="11sp" android:layout_marginBottom="4dp"/>

        <EditText android:id="@+id/etWolBroadcast"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:background="@drawable/bg_field" android:textColor="#FFFFFF"
            android:textSize="13sp" android:hint="255.255.255.255"
            android:textColorHint="#4A5568" android:paddingHorizontal="12dp"
            android:fontFamily="monospace" android:inputType="number|numberDecimal|numberSigned"
            android:layout_marginBottom="14dp"/>

        <Button android:id="@+id/btnWolWake"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="🔌 إيقاظ الحاسوب" android:textColor="#FFFFFF"
            android:textSize="14sp" android:textStyle="bold"
            android:background="@drawable/bg_btn_green"/>

        <TextView android:id="@+id/tvWolResult"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="#94A3B8" android:textSize="13sp"
            android:gravity="center" android:layout_marginTop="12dp"
            android:fontFamily="monospace"/>

    </LinearLayout>

    <!-- Info card -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@drawable/bg_card" android:padding="14dp"
        android:orientation="vertical">

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="💡 كيف تعمل؟" android:textColor="#F59E0B"
            android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="1. فعّل Wake-on-LAN في BIOS الحاسوب\n2. احصل على MAC Address:\n   Windows: ipconfig /all\n   Linux: ip link show\n3. أدخل الـ MAC وضغط إيقاظ"
            android:textColor="#64748B" android:textSize="11sp"
            android:lineSpacingMultiplier="1.6" android:fontFamily="monospace"/>

    </LinearLayout>

</LinearLayout>
</ScrollView>
