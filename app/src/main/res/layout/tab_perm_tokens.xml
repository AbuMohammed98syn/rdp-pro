<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#050810">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="14dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@drawable/bg_card" android:padding="14dp"
        android:orientation="vertical" android:layout_marginBottom="10dp">

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="🔑 Token بصلاحيات محددة" android:textColor="#F59E0B"
            android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="12dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:gravity="center_vertical" android:layout_marginBottom="10dp">
            <TextView android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="نوع الصلاحية" android:textColor="#94A3B8" android:textSize="12sp"/>
            <Spinner android:id="@+id/spinnerPermType"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:backgroundTint="#F59E0B"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:gravity="center_vertical" android:layout_marginBottom="12dp">
            <TextView android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="مدة الصلاحية" android:textColor="#94A3B8" android:textSize="12sp"/>
            <Spinner android:id="@+id/spinnerPermExpiry"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:backgroundTint="#F59E0B"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGenPermToken"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:text="🔑 إنشاء Token مقيّد"
            android:textColor="#FFFFFF" android:textSize="13sp"
            app:backgroundTint="#92400E" app:cornerRadius="8dp"/>

        <TextView android:id="@+id/tvPermTokenResult"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="#FCD34D" android:textSize="10sp" android:fontFamily="monospace"
            android:background="@drawable/bg_field" android:padding="8dp"
            android:layout_marginTop="8dp" android:visibility="gone"
            android:lineSpacingMultiplier="1.5"/>

        <Button android:id="@+id/btnCopyPermToken"
            android:layout_width="wrap_content" android:layout_height="32dp"
            android:text="نسخ 📋" android:textSize="11sp"
            android:textColor="#FCD34D" android:background="@drawable/bg_btn_dark"
            android:paddingHorizontal="12dp" android:layout_marginTop="6dp"
            android:visibility="gone"/>

    </LinearLayout>

</LinearLayout>
</ScrollView>
