<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#050810">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="14dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@drawable/bg_card" android:padding="16dp"
        android:orientation="vertical" android:layout_marginBottom="10dp">

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="🔕 الخدمة الخلفية" android:textColor="#FFFFFF"
            android:textSize="15sp" android:textStyle="bold" android:layout_marginBottom="6dp"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="يبقي الاتصال بالحاسوب نشطاً حتى بدون فتح التطبيق\nإشعار دائم مع الحالة + أزرار قطع وقفل"
            android:textColor="#64748B" android:textSize="11sp" android:lineSpacingMultiplier="1.5"
            android:layout_marginBottom="14dp"/>

        <TextView android:id="@+id/tvBgInfo"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="⏹ الخدمة متوقفة" android:textColor="#4A5568"
            android:textSize="12sp" android:fontFamily="monospace"
            android:background="@drawable/bg_field" android:padding="10dp"
            android:layout_marginBottom="12dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:gravity="center_vertical" android:layout_marginBottom="10dp">
            <TextView android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="تشغيل عند إعادة التشغيل" android:textColor="#94A3B8"
                android:textSize="12sp"/>
            <Switch android:id="@+id/swBgStartOnBoot"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:thumbTint="#3B82F6" android:trackTint="#1E3A5F"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBgStart"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:text="▶ تشغيل الخدمة الخلفية"
            android:textColor="#FFFFFF" android:textSize="13sp"
            app:backgroundTint="#064E3B" app:cornerRadius="10dp"
            android:layout_marginBottom="6dp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBgStop"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:text="⏹ إيقاف الخدمة"
            android:textColor="#FFFFFF" android:textSize="13sp"
            app:backgroundTint="#7F1D1D" app:cornerRadius="10dp"
            android:enabled="false"/>
    </LinearLayout>

    <!-- Info card -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@drawable/bg_card" android:padding="14dp"
        android:orientation="vertical">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="ما تقدر تفعل من الإشعار:" android:textColor="#94A3B8"
            android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="• قطع الاتصال مباشرة\n• قفل شاشة الحاسوب\n• فتح التطبيق للعودة للتحكم\n• تنبيه تلقائي عند CPU > 80%"
            android:textColor="#64748B" android:textSize="11sp" android:lineSpacingMultiplier="1.8"/>
    </LinearLayout>

</LinearLayout>
</ScrollView>
