<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="44dp"
    android:background="@drawable/bg_card" android:gravity="center_vertical"
    android:paddingHorizontal="14dp" android:layout_marginBottom="4dp"
    android:clickable="true" android:focusable="true"
    android:foreground="?attr/selectableItemBackground">
    <View android:layout_width="6dp" android:layout_height="6dp"
        android:background="@drawable/dot_green" android:layout_marginEnd="10dp"/>
    <TextView android:id="@+id/tvHistAddr"
        android:layout_width="0dp" android:layout_weight="1"
        android:layout_height="wrap_content"
        android:textColor="#94A3B8" android:textSize="12sp"
        android:fontFamily="monospace"/>
    <TextView android:id="@+id/tvHistTime"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="#4A5568" android:textSize="10sp"/>
</LinearLayout>
