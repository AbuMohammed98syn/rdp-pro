<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#050810">

    <!-- Dir header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@drawable/bg_card" android:padding="10dp"
        android:gravity="center_vertical" android:layout_margin="8dp">
        <TextView android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="مجلد الحاسوب:" android:textColor="#64748B" android:textSize="10sp"/>
        <TextView android:id="@+id/tvSyncDir"
            android:layout_width="0dp" android:layout_weight="2"
            android:layout_height="wrap_content"
            android:textColor="#22D3EE" android:textSize="11sp" android:fontFamily="monospace"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChangeDir"
            android:layout_width="wrap_content" android:layout_height="30dp"
            android:text="تغيير" android:textSize="9sp" android:textColor="#FFFFFF"
            app:backgroundTint="#1E3A5F" app:cornerRadius="6dp"
            android:paddingHorizontal="10dp"/>
    </LinearLayout>

    <!-- Action buttons -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:paddingHorizontal="8dp" android:layout_marginBottom="6dp">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRunDiff"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="36dp" android:text="🔍 مقارنة"
            android:textColor="#FFFFFF" android:textSize="10sp"
            app:backgroundTint="#1E3A5F" app:cornerRadius="8dp"
            android:layout_marginEnd="4dp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSyncUp"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="36dp" android:text="📤 رفع"
            android:textColor="#FFFFFF" android:textSize="10sp"
            app:backgroundTint="#064E3B" app:cornerRadius="8dp"
            android:layout_marginEnd="4dp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSyncDown"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="36dp" android:text="📥 تنزيل"
            android:textColor="#FFFFFF" android:textSize="10sp"
            app:backgroundTint="#1E3A5F" app:cornerRadius="8dp"
            android:layout_marginEnd="4dp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPickFile"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="36dp" android:text="📎 رفع ملف"
            android:textColor="#FCD34D" android:textSize="10sp"
            app:backgroundTint="#111107" app:strokeColor="#F59E0B"
            app:strokeWidth="1dp" app:cornerRadius="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
    </LinearLayout>

    <!-- Status + progress -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:paddingHorizontal="10dp" android:gravity="center_vertical"
        android:layout_marginBottom="4dp">
        <TextView android:id="@+id/tvSyncStatus"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="اضغط 'مقارنة' للبدء" android:textColor="#4A5568"
            android:textSize="11sp"/>
        <ProgressBar android:id="@+id/progSync"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:visibility="gone" android:indeterminate="true"
            android:indeterminateTint="#3B82F6"/>
    </LinearLayout>

    <!-- Diff list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDiff"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:padding="6dp"
        android:clipToPadding="false"/>
</LinearLayout>
