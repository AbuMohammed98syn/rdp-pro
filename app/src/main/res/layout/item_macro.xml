<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:background="@drawable/bg_card" android:padding="10dp"
    android:orientation="vertical" android:layout_marginBottom="5dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:gravity="center_vertical">
        <TextView android:id="@+id/tvMacroName"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvMacroCount"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#4A5568" android:textSize="9sp" android:fontFamily="monospace"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:gravity="end" android:layout_marginTop="6dp">
        <Button android:id="@+id/btnLoopMacro"
            android:layout_width="wrap_content" android:layout_height="28dp"
            android:text="🔄 loop" android:textSize="9sp" android:textColor="#8B5CF6"
            android:background="@drawable/bg_btn_dark" android:paddingHorizontal="8dp"
            android:layout_marginEnd="4dp"/>
        <Button android:id="@+id/btnEditMacro"
            android:layout_width="wrap_content" android:layout_height="28dp"
            android:text="✏" android:textSize="10sp" android:textColor="#94A3B8"
            android:background="@drawable/bg_btn_dark" android:paddingHorizontal="8dp"
            android:layout_marginEnd="4dp"/>
        <Button android:id="@+id/btnDelMacro"
            android:layout_width="wrap_content" android:layout_height="28dp"
            android:text="🗑" android:textSize="10sp" android:textColor="#EF4444"
            android:background="@drawable/bg_btn_dark" android:paddingHorizontal="8dp"
            android:layout_marginEnd="4dp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRunMacro"
            android:layout_width="wrap_content" android:layout_height="28dp"
            android:text="▶ تشغيل" android:textSize="10sp" android:textColor="#FFFFFF"
            app:backgroundTint="#064E3B" app:cornerRadius="6dp"
            android:paddingHorizontal="12dp"/>
    </LinearLayout>
</LinearLayout>
