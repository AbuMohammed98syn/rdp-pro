<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#050810">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="10dp">

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="─── تعديل ───" android:textColor="#4A5568" android:textSize="9sp"
        android:gravity="center" android:layout_marginVertical="6dp"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp">
        <Button android:id="@+id/hkCtrlC"  android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="Ctrl+C" android:textSize="9sp" android:textColor="#94A3B8" android:background="@drawable/bg_btn_dark"/>
        <Space android:layout_width="4dp" android:layout_height="1dp"/>
        <Button android:id="@+id/hkCtrlV"  android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="Ctrl+V" android:textSize="9sp" android:textColor="#94A3B8" android:background="@drawable/bg_btn_dark"/>
        <Space android:layout_width="4dp" android:layout_height="1dp"/>
        <Button android:id="@+id/hkCtrlX"  android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="Ctrl+X" android:textSize="9sp" android:textColor="#94A3B8" android:background="@drawable/bg_btn_dark"/>
        <Space android:layout_width="4dp" android:layout_height="1dp"/>
        <Button android:id="@+id/hkCtrlZ"  android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="Ctrl+Z" android:textSize="9sp" android:textColor="#94A3B8" android:background="@drawable/bg_btn_dark"/>
        <Space android:layout_width="4dp" android:layout_height="1dp"/>
        <Button android:id="@+id/hkCtrlA"  android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="Ctrl+A" android:textSize="9sp" android:textColor="#94A3B8" android:background="@drawable/bg_btn_dark"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp">
        <Button android:id="@+id/hkCtrlS"  android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="Ctrl+S" android:textSize="9sp" android:textColor="#94A3B8" android:background="@drawable/bg_btn_dark"/>
        <Space android:layout_width="4dp" android:layout_height="1dp"/>
        <Button android:id="@+id/hkCtrlF"  android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="Ctrl+F" android:textSize="9sp" android:textColor="#94A3B8" android:background="@drawable/bg_btn_dark"/>
        <Space android:layout_width="4dp" android:layout_height="1dp"/>
        <Button android:id="@+id/hkCtrlW"  android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="Ctrl+W" android:textSize="9sp" android:textColor="#94A3B8" android:background="@drawable/bg_btn_dark"/>
        <Space android:layout_width="4dp" android:layout_height="1dp"/>
        <Button android:id="@+id/hkCtrlT"  android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="Ctrl+T" android:textSize="9sp" android:textColor="#94A3B8" android:background="@drawable/bg_btn_dark"/>
        <Space android:layout_width="4dp" android:layout_height="1dp"/>
        <Button android:id="@+id/hkCtrlN"  android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="Ctrl+N" android:textSize="9sp" android:textColor="#94A3B8" android:background="@drawable/bg_btn_dark"/>
    </LinearLayout>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="─── Windows ───" android:textColor="#4A5568" android:textSize="9sp"
        android:gravity="center" android:layout_marginVertical="6dp"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp">
        <Button android:id="@+id/hkAltF4"   android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="Alt+F4"   android:textSize="9sp" android:textColor="#F87171" android:background="@drawable/bg_btn_dark"/>
        <Space android:layout_width="4dp" android:layout_height="1dp"/>
        <Button android:id="@+id/hkAltTab"  android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="Alt+Tab"  android:textSize="9sp" android:textColor="#94A3B8" android:background="@drawable/bg_btn_dark"/>
        <Space android:layout_width="4dp" android:layout_height="1dp"/>
        <Button android:id="@+id/hkWinD"    android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="Win+D"    android:textSize="9sp" android:textColor="#94A3B8" android:background="@drawable/bg_btn_dark"/>
        <Space android:layout_width="4dp" android:layout_height="1dp"/>
        <Button android:id="@+id/hkWinE"    android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="Win+E"    android:textSize="9sp" android:textColor="#94A3B8" android:background="@drawable/bg_btn_dark"/>
        <Space android:layout_width="4dp" android:layout_height="1dp"/>
        <Button android:id="@+id/hkWinL"    android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="Win+L"    android:textSize="9sp" android:textColor="#F59E0B" android:background="@drawable/bg_btn_dark"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content">
        <Button android:id="@+id/hkWinR"      android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="Win+R"        android:textSize="9sp" android:textColor="#94A3B8" android:background="@drawable/bg_btn_dark"/>
        <Space android:layout_width="4dp" android:layout_height="1dp"/>
        <Button android:id="@+id/hkTaskMgr"   android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="Ctrl+⇧+Esc"  android:textSize="8sp" android:textColor="#A78BFA" android:background="@drawable/bg_btn_dark"/>
        <Space android:layout_width="4dp" android:layout_height="1dp"/>
        <Button android:id="@+id/hkPrintScr"  android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="PrtSc"        android:textSize="9sp" android:textColor="#94A3B8" android:background="@drawable/bg_btn_dark"/>
        <Space android:layout_width="4dp" android:layout_height="1dp"/>
        <Button android:id="@+id/hkCtrlShiftN" android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="Ctrl+⇧+N"   android:textSize="8sp" android:textColor="#94A3B8" android:background="@drawable/bg_btn_dark"/>
        <Space android:layout_width="4dp" android:layout_height="1dp"/>
        <Button android:id="@+id/hkAltPrtSc"  android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="Alt+PrtSc"   android:textSize="8sp" android:textColor="#94A3B8" android:background="@drawable/bg_btn_dark"/>
    </LinearLayout>

</LinearLayout>
</ScrollView>
