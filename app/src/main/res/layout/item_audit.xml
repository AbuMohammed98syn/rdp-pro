<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:background="@drawable/bg_card"
    android:padding="8dp" android:layout_marginBottom="3dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:gravity="center_vertical">
        <TextView android:id="@+id/tvAuditAction"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="#3B82F6" android:textSize="11sp"
            android:fontFamily="monospace" android:textStyle="bold"/>
        <TextView android:id="@+id/tvAuditTs"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#4A5568" android:textSize="9sp" android:fontFamily="monospace"/>
    </LinearLayout>
    <TextView android:id="@+id/tvAuditDetail"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textColor="#64748B" android:textSize="10sp" android:fontFamily="monospace"/>
</LinearLayout>
