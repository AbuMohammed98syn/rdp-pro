<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#050810">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="14dp">

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="⚙️ إعدادات البث" android:textColor="#FFFFFF"
        android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="10dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@drawable/bg_card" android:padding="14dp"
        android:orientation="vertical" android:layout_marginBottom="8dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="جودة الصورة" android:textColor="#94A3B8" android:textSize="11sp"/>
            <TextView android:id="@+id/tvQualityVal"
                android:layout_width="40dp" android:layout_height="wrap_content"
                android:textColor="#60A5FA" android:textSize="11sp" android:textStyle="bold"
                android:gravity="end"/>
        </LinearLayout>
        <com.google.android.material.slider.Slider android:id="@+id/sliderQuality"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:valueFrom="10" android:valueTo="95" android:stepSize="5"
            app:thumbColor="#3B82F6" app:trackColorActive="#3B82F6" app:trackColorInactive="#1A2540"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@drawable/bg_card" android:padding="14dp"
        android:orientation="vertical" android:layout_marginBottom="8dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="معدل الإطارات (FPS)" android:textColor="#94A3B8" android:textSize="11sp"/>
            <TextView android:id="@+id/tvFpsVal"
                android:layout_width="50dp" android:layout_height="wrap_content"
                android:textColor="#10B981" android:textSize="11sp" android:textStyle="bold"
                android:gravity="end"/>
        </LinearLayout>
        <com.google.android.material.slider.Slider android:id="@+id/sliderFps"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:valueFrom="5" android:valueTo="60" android:stepSize="5"
            app:thumbColor="#10B981" app:trackColorActive="#10B981" app:trackColorInactive="#1A2540"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@drawable/bg_card" android:padding="14dp"
        android:orientation="vertical" android:layout_marginBottom="8dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="حجم الصورة (Scale)" android:textColor="#94A3B8" android:textSize="11sp"/>
            <TextView android:id="@+id/tvScaleVal"
                android:layout_width="40dp" android:layout_height="wrap_content"
                android:textColor="#F59E0B" android:textSize="11sp" android:textStyle="bold"
                android:gravity="end"/>
        </LinearLayout>
        <com.google.android.material.slider.Slider android:id="@+id/sliderScale"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:valueFrom="0.3" android:valueTo="2.0" android:stepSize="0.1"
            app:thumbColor="#F59E0B" app:trackColorActive="#F59E0B" app:trackColorInactive="#1A2540"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@drawable/bg_card" android:padding="14dp"
        android:orientation="vertical" android:layout_marginBottom="8dp">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="الشاشة المعروضة" android:textColor="#94A3B8"
            android:textSize="11sp" android:layout_marginBottom="6dp"/>
        <Spinner android:id="@+id/spinnerMonitor"
            android:layout_width="match_parent" android:layout_height="40dp"
            android:background="@drawable/bg_field"/>
    </LinearLayout>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="معلومات الخادم" android:textColor="#FFFFFF"
        android:textSize="13sp" android:textStyle="bold"
        android:layout_marginTop="10dp" android:layout_marginBottom="8dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@drawable/bg_card" android:padding="14dp"
        android:orientation="vertical" android:layout_marginBottom="8dp">
        <TextView android:id="@+id/tvConnInfo"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="#64748B" android:textSize="11sp"
            android:fontFamily="monospace" android:lineSpacingMultiplier="1.5"
            android:text="جاري التحميل..."/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">
        <Button android:id="@+id/btnTestConn"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="42dp"
            android:text="🏓 قياس الاتصال" android:textSize="11sp" android:textColor="#94A3B8"
            android:background="@drawable/bg_btn_dark"/>
        <Space android:layout_width="8dp" android:layout_height="1dp"/>
        <TextView android:id="@+id/tvLatency"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="42dp"
            android:textColor="#10B981" android:textSize="18sp" android:textStyle="bold"
            android:fontFamily="monospace" android:gravity="center"/>
    </LinearLayout>

    <Button android:id="@+id/btnDisconnect"
        android:layout_width="match_parent" android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:text="⏏ قطع الاتصال والخروج" android:textColor="#EF4444"
        android:textSize="12sp" android:background="@drawable/bg_btn_red"/>

    <Space android:layout_width="match_parent" android:layout_height="20dp"/>
</LinearLayout>
</ScrollView>