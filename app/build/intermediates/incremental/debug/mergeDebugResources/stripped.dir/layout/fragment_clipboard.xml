<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#050810">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="14dp">

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="الحافظة المشتركة" android:textColor="#94A3B8"
        android:textSize="11sp" android:layout_marginBottom="8dp"/>

    <EditText android:id="@+id/etClipboard"
        android:layout_width="match_parent" android:layout_height="120dp"
        android:background="@drawable/bg_card" android:textColor="#FFFFFF"
        android:hint="نص الحافظة..." android:textColorHint="#4A5568"
        android:padding="12dp" android:textSize="13sp" android:gravity="top"
        android:inputType="textMultiLine" android:fontFamily="monospace"/>

    <TextView android:id="@+id/tvClipStatus"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textColor="#10B981" android:textSize="11sp"
        android:layout_marginTop="4dp" android:layout_marginBottom="12dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content">
        <Button android:id="@+id/btnPushClip"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="42dp"
            android:text="دفع للحاسوب ↑" android:textSize="11sp" android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn_blue"/>
        <Space android:layout_width="8dp" android:layout_height="1dp"/>
        <Button android:id="@+id/btnPullClip"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="42dp"
            android:text="سحب من الحاسوب ↓" android:textSize="11sp" android:textColor="#94A3B8"
            android:background="@drawable/bg_btn_dark"/>
    </LinearLayout>

    <Button android:id="@+id/btnCopyLocal"
        android:layout_width="match_parent" android:layout_height="38dp"
        android:layout_marginTop="8dp"
        android:text="نسخ للهاتف 📋" android:textSize="11sp" android:textColor="#22D3EE"
        android:background="@drawable/bg_btn_dark"/>

</LinearLayout>
</ScrollView>
