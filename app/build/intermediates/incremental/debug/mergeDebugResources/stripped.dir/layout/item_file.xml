<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:background="@drawable/bg_card" android:padding="10dp"
    android:gravity="center_vertical" android:layout_marginBottom="3dp"
    android:clickable="true" android:focusable="true"
    android:foreground="?attr/selectableItemBackground">
    <TextView android:id="@+id/tvFileIcon"
        android:layout_width="32dp" android:layout_height="32dp"
        android:textSize="20sp" android:gravity="center"/>
    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
        android:layout_height="wrap_content" android:orientation="vertical"
        android:layout_marginHorizontal="8dp">
        <TextView android:id="@+id/tvFileName"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#E2E8F0" android:textSize="12sp"
            android:singleLine="true"/>
        <TextView android:id="@+id/tvFileMeta"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#4A5568" android:textSize="9sp"/>
    </LinearLayout>
    <TextView android:id="@+id/btnFileMore"
        android:layout_width="32dp" android:layout_height="32dp"
        android:text="⋯" android:textSize="16sp" android:textColor="#4A5568"
        android:gravity="center" android:clickable="true" android:focusable="true"/>
</LinearLayout>
