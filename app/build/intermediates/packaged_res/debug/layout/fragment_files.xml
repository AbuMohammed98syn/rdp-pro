<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#050810">

    <!-- Breadcrumb -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="40dp"
        android:background="#090D17" android:gravity="center_vertical" android:paddingHorizontal="10dp">
        <Button android:id="@+id/btnUp" android:layout_width="32dp" android:layout_height="32dp"
            android:text="↑" android:textSize="14sp" android:textColor="#94A3B8"
            android:background="@drawable/bg_btn_dark" android:padding="0dp"/>
        <Button android:id="@+id/btnHome" android:layout_width="32dp" android:layout_height="32dp"
            android:text="🏠" android:textSize="13sp" android:textColor="#94A3B8"
            android:background="@drawable/bg_btn_dark" android:padding="0dp"
            android:layout_marginStart="4dp"/>
        <TextView android:id="@+id/tvFilePath"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="#94A3B8" android:textSize="10sp"
            android:fontFamily="monospace" android:singleLine="true"
            android:layout_marginHorizontal="8dp"/>
        <Button android:id="@+id/btnNewFolder" android:layout_width="32dp" android:layout_height="32dp"
            android:text="+" android:textSize="16sp" android:textColor="#60A5FA"
            android:background="@drawable/bg_btn_blue" android:padding="0dp"/>
    </LinearLayout>

    <!-- Quick Links Chips -->
    <HorizontalScrollView android:layout_width="match_parent" android:layout_height="38dp"
        android:background="#090D17">
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipQuickLinks"
            android:layout_width="wrap_content" android:layout_height="match_parent"
            android:paddingHorizontal="8dp" app:singleSelection="true"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>
    </HorizontalScrollView>

    <!-- Upload bar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="40dp"
        android:background="#090D17" android:gravity="center_vertical"
        android:paddingHorizontal="10dp">
        <TextView android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="📤 رفع ملف من الهاتف → الحاسوب"
            android:textColor="#4A5568" android:textSize="10sp"/>
        <Button android:id="@+id/btnUpload"
            android:layout_width="wrap_content" android:layout_height="28dp"
            android:text="اختر ملف" android:textSize="10sp" android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn_blue" android:paddingHorizontal="10dp"/>
    </LinearLayout>

    <!-- Progress -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/fileProgress"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:visibility="gone"
        app:indicatorColor="#2563EB" app:trackColor="#1A2540"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

    <!-- Empty state -->
    <TextView android:id="@+id/tvEmpty"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="المجلد فارغ" android:textColor="#4A5568"
        android:gravity="center" android:padding="24dp"
        android:visibility="gone"/>

    <!-- File list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFiles"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="6dp"/>

</LinearLayout>
