<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#060910">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="28dp">

        <Space android:layout_width="match_parent" android:layout_height="48dp"/>

        <LinearLayout android:layout_width="80dp" android:layout_height="80dp"
            android:layout_gravity="center" android:gravity="center"
            android:background="@drawable/bg_icon">
            <ImageView android:layout_width="40dp" android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_slideshow"
                android:tint="#FFFFFF"/>
        </LinearLayout>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Remote Desktop Pro" android:textColor="#FFFFFF"
            android:textSize="20sp" android:textStyle="bold"
            android:gravity="center" android:layout_marginTop="16dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="v2.2" android:textColor="#4A5568"
            android:textSize="12sp" android:gravity="center" android:layout_marginBottom="40dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="IP الحاسوب" android:textColor="#94A3B8" android:textSize="12sp" android:layout_marginBottom="8dp"/>

        <EditText android:id="@+id/etIp"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:background="@drawable/bg_field"
            android:textColor="#FFFFFF" android:hint="192.168.1.x"
            android:inputType="numberDecimal|numberSigned"
            android:paddingStart="16dp"
            android:digits="0123456789." android:textSize="15sp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="المنفذ" android:textColor="#94A3B8"
            android:textSize="12sp" android:layout_marginTop="16dp" android:layout_marginBottom="8dp"/>

        <EditText android:id="@+id/etPort"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:background="@drawable/bg_field"
            android:textColor="#FFFFFF" android:hint="8000"
            android:inputType="number"
            android:paddingStart="16dp" android:textSize="15sp"/>

        <TextView android:id="@+id/tvError"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="#F87171" android:textSize="12sp"
            android:layout_marginTop="8dp" android:visibility="gone"/>

        <Button android:id="@+id/btnConnect"
            android:layout_width="match_parent" android:layout_height="54dp"
            android:layout_marginTop="24dp" android:text="اتصال"
            android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold"
            android:background="@drawable/bg_btn_blue"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="الاتصالات السابقة" android:textColor="#4A5568"
            android:textSize="11sp" android:layout_marginTop="32dp" android:layout_marginBottom="8dp"/>

        <ListView android:id="@+id/lvHistory"
            android:layout_width="match_parent" android:layout_height="200dp"
            android:divider="#1E2E4A" android:dividerHeight="1dp"/>

    </LinearLayout>
</ScrollView>
