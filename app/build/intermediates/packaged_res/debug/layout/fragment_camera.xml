<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:gravity="center" android:background="#060910"
    android:padding="24dp">

    <ImageView android:layout_width="64dp" android:layout_height="64dp"
        android:src="@android:drawable/ic_menu_camera" android:tint="#4A5568"/>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="بث الكاميرا" android:textColor="#FFFFFF"
        android:textSize="18sp" android:textStyle="bold"
        android:gravity="center" android:layout_marginTop="16dp"/>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="افتح المتصفح على الهاتف وانتقل إلى:"
        android:textColor="#94A3B8" android:textSize="13sp"
        android:gravity="center" android:layout_marginTop="8dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@drawable/bg_field" android:padding="14dp"
        android:layout_marginTop="12dp" android:gravity="center">
        <TextView android:id="@+id/tvCameraUrl"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="http://192.168.1.x:8000/mobile"
            android:textColor="#60A5FA" android:textSize="14sp"
            android:fontFamily="monospace" android:textStyle="bold"/>
    </LinearLayout>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="ثم افتح على الحاسوب:\nhttp://localhost:8000/pc"
        android:textColor="#4A5568" android:textSize="11sp"
        android:gravity="center" android:layout_marginTop="16dp"/>

</LinearLayout>
